
    public static boolean Fim(String str) {
        return str.length() == 3 && str.charAt(0) == 'F' && str.charAt(1) == 'I' && str.charAt(2) == 'M';
    }
        public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        boolean fim;
        do {
            String str = sc.nextLine();
            fim = Fim(str);
            if (!fim)
            System.out.println();
        } while (!fim);
        sc.close();
    }

